{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/prompt-performance/1.0.0/visual-review-submission.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "reviewer_id",
    "packet_sha256",
    "decisions",
    "submission_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "reviewer_id": {"type": "string", "minLength": 1},
    "packet_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "decisions": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "winner", "reason", "scores"],
        "properties": {
          "case_id": {"type": "string", "minLength": 1},
          "winner": {"enum": ["A", "B", "tie"]},
          "reason": {"type": "string", "minLength": 20},
          "scores": {"type": "object", "minProperties": 3}
        }
      }
    },
    "submission_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
