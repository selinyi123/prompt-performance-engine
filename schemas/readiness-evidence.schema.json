{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/prompt-performance/1.0.0/readiness-evidence.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_id",
    "kind",
    "facts",
    "provenance",
    "limitations",
    "evidence_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "report_id": {"type": "string", "minLength": 1},
    "kind": {
      "enum": [
        "operational_verification",
        "code_execution",
        "image_review",
        "expert_review_coverage",
        "independent_reproduction",
        "defect_register",
        "claims_audit"
      ]
    },
    "facts": {"type": "object"},
    "provenance": {"type": "object"},
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "evidence_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
