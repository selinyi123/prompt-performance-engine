{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/prompt-performance/1.0.0/visual-review-packet.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "reviewer_id",
    "generation_manifest_sha256",
    "instructions",
    "items",
    "packet_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "reviewer_id": {"type": "string", "minLength": 1},
    "generation_manifest_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "instructions": {
      "type": "object",
      "required": [
        "blind",
        "winner_values",
        "score_range",
        "minimum_reason_characters"
      ]
    },
    "items": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "input_text",
          "rubric",
          "image_a",
          "image_b"
        ],
        "properties": {
          "case_id": {"type": "string", "minLength": 1},
          "input_text": {"type": "string", "minLength": 1},
          "rubric": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "image_a": {"$ref": "#/$defs/blindImage"},
          "image_b": {"$ref": "#/$defs/blindImage"}
        }
      }
    },
    "packet_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "blindImage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "mime_type", "width", "height"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^review-assets/[0-9a-f]{16}/[0-9a-f]{32}\\.png$"
        },
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "mime_type": {"const": "image/png"},
        "width": {"type": "integer", "minimum": 256},
        "height": {"type": "integer", "minimum": 256}
      }
    }
  }
}
